@model Gamingv1.ViewModels.UserDetailsViewModel
@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-user"></i> User Details: @Model.User.Name
        </h1>
        <div>
            <a href="@Url.Action("UsersWithRoles")" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to Users
            </a>
            <a href="@Url.Action("EditUser", new { id = Model.User.Id })" class="btn btn-primary btn-sm">
                <i class="fas fa-edit"></i> Edit User
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="close" data-dismiss="alert">
                <span>&times;</span>
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="close" data-dismiss="alert">
                <span>&times;</span>
            </button>
        </div>
    }

    <div class="row">
        <!-- User Information -->
        <div class="col-md-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">User Information</h6>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.User.ProfileImage))
                        {
                            <img src="@Model.User.ProfileImage" alt="@Model.User.Name's profile" class="img-profile rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="img-profile rounded-circle bg-light d-flex align-items-center justify-content-center mb-3" style="width: 150px; height: 150px; margin: 0 auto;">
                                <i class="fas fa-user fa-4x text-gray-300"></i>
                            </div>
                        }
                        <a href="@Url.Action("UploadUserProfileImage", new { id = Model.User.Id })" class="btn btn-sm btn-primary">
                            <i class="fas fa-camera"></i> @(string.IsNullOrEmpty(Model.User.ProfileImage) ? "Upload Profile Picture" : "Change Profile Picture")
                        </a>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th>Name</th>
                                    <td>@Model.User.Name</td>
                                </tr>
                                <tr>
                                    <th>Email</th>
                                    <td>@Model.User.Email</td>
                                </tr>
                                <tr>
                                    <th>Phone</th>
                                    <td>@(string.IsNullOrEmpty(Model.User.PhoneNumber) ? "Not provided" : Model.User.PhoneNumber)</td>
                                </tr>
                                <tr>
                                    <th>Registered</th>
                                    <td>@Model.User.CreatedAt.ToString("MMM dd, yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>
                                        @if (Model.User.LockoutEnd != null && Model.User.LockoutEnd > DateTime.Now)
                                        {
                                            <span class="badge badge-danger">Locked</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th>Roles</th>
                                    <td>
                                        @foreach (var role in Model.Roles)
                                        {
                                            <span class="badge badge-info mr-1">@role</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("EditUser", new { id = Model.User.Id })" class="btn btn-primary btn-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            @if (Model.User.LockoutEnd != null && Model.User.LockoutEnd > DateTime.Now)
                            {
                                <a href="@Url.Action("UnlockUser", new { id = Model.User.Id })" class="btn btn-success btn-sm">
                                    <i class="fas fa-unlock"></i> Unlock
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("LockUser", new { id = Model.User.Id })" class="btn btn-warning btn-sm">
                                    <i class="fas fa-lock"></i> Lock
                                </a>
                            }
                            <a href="@Url.Action("ResetUserPassword", new { id = Model.User.Id })" 
                               class="btn btn-info btn-sm"
                               data-toggle="modal" 
                               data-target="#resetPasswordModal">
                                <i class="fas fa-key"></i> Reset Password
                            </a>
                            @if (!Model.Roles.Contains("Admin"))
                            {
                                <a href="@Url.Action("DeleteUser", new { userId = Model.User.Id })" 
                                   class="btn btn-danger btn-sm"
                                   data-toggle="modal" 
                                   data-target="#deleteUserModal">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Activity and Relationships -->
        <div class="col-md-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Game Purchases</h6>
                </div>
                <div class="card-body">
                    @if (Model.GamePurchases.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm">
                                <thead>
                                    <tr>
                                        <th>Game</th>
                                        <th>Purchase Date</th>
                                        <th>Price</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var purchase in Model.GamePurchases)
                                    {
                                        <tr>
                                            <td>@purchase.Game.Title</td>
                                            <td>@purchase.PurchaseDate.ToString("MMM dd, yyyy")</td>
                                            <td>$@purchase.FinalPrice</td>
                                            <td>
                                                @if (purchase.PaymentStatus == PaymentStatus.Paid)
                                                {
                                                    <span class="badge badge-success">Paid</span>
                                                }
                                                else if (purchase.PaymentStatus == PaymentStatus.Pending)
                                                {
                                                    <span class="badge badge-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Failed</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">No game purchases found.</p>
                    }
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Event Registrations</h6>
                </div>
                <div class="card-body">
                    @if (Model.EventRegistrations.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm">
                                <thead>
                                    <tr>
                                        <th>Event</th>
                                        <th>Registration Date</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var registration in Model.EventRegistrations)
                                    {
                                        <tr>
                                            <td>@registration.Event.Title</td>
                                            <td>@registration.RegistrationDate.ToString("MMM dd, yyyy")</td>
                                            <td>$@registration.AmountPaid</td>
                                            <td>
                                                @if (registration.PaymentStatus == PaymentStatus.Paid)
                                                {
                                                    <span class="badge badge-success">Paid</span>
                                                }
                                                else if (registration.PaymentStatus == PaymentStatus.Pending)
                                                {
                                                    <span class="badge badge-warning">Pending</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Failed</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">No event registrations found.</p>
                    }
                </div>
            </div>

            @if (Model.Roles.Contains("Parent") || Model.Roles.Contains("Student"))
            {
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Family Relationships</h6>
                    </div>
                    <div class="card-body">
                        @if (Model.Roles.Contains("Parent"))
                        {
                            <h6 class="font-weight-bold">Children:</h6>
                            @if (Model.Children.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var child in Model.Children)
                                            {
                                                <tr>
                                                    <td>@child.Name</td>
                                                    <td>@child.Email</td>
                                                    <td>
                                                        <a href="@Url.Action("UserDetails", new { id = child.Id })" class="btn btn-sm btn-info">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No children linked to this parent.</p>
                            }
                        }

                        @if (Model.Roles.Contains("Student"))
                        {
                            <h6 class="font-weight-bold mt-3">Parents:</h6>
                            @if (Model.Parents.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-bordered table-sm">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var parent in Model.Parents)
                                            {
                                                <tr>
                                                    <td>@parent.Name</td>
                                                    <td>@parent.Email</td>
                                                    <td>
                                                        <a href="@Url.Action("UserDetails", new { id = parent.Id })" class="btn btn-sm btn-info">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No parents linked to this student.</p>
                            }
                        }
                    </div>
                </div>
            }

            @if (Model.Roles.Contains("Teacher") || Model.Roles.Contains("Student"))
            {
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            @(Model.Roles.Contains("Teacher") ? "Classes Teaching" : "Classes Enrolled")
                        </h6>
                    </div>
                    <div class="card-body">
                        @if (Model.Classes.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <th>Class Name</th>
                                            <th>Join Code</th>
                                            <th>Created</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var cls in Model.Classes)
                                        {
                                            <tr>
                                                <td>@cls.ClassName</td>
                                                <td>@cls.JoinCode</td>
                                                <td>@cls.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center">No classes found.</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reset User Password</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to reset the password for <strong>@Model.User.Name</strong>?</p>
                <p>A temporary password will be generated and sent to the user's email.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <a href="@Url.Action("ResetUserPassword", new { id = Model.User.Id })" class="btn btn-primary">Reset Password</a>
            </div>
        </div>
    </div>
</div>

<!-- Delete User Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Delete User</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong>@Model.User.Name</strong>?</p>
                <p class="text-danger">This action cannot be undone. All data associated with this user will be permanently deleted.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <a href="@Url.Action("DeleteUser", new { userId = Model.User.Id })" class="btn btn-danger">Delete User</a>
            </div>
        </div>
    </div>
</div>
