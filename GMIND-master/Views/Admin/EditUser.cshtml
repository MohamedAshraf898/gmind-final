@model Gamingv1.ViewModels.UserEditViewModel
@{
    ViewData["Title"] = "Edit User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-user-edit"></i> Edit User
        </h1>
        <div>
            <a href="@Url.Action("UserDetails", new { id = Model.Id })" class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to User Details
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Edit User Information</h6>
        </div>
        <div class="card-body">
            <form asp-action="EditUser" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="form-group">
                    <label asp-for="Name" class="font-weight-bold">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter user's name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email" class="font-weight-bold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="Enter user's email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber" class="font-weight-bold">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="Enter user's phone number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>

                <hr />
                <div class="form-group text-right">
                    <a href="@Url.Action("UserDetails", new { id = Model.Id })" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
