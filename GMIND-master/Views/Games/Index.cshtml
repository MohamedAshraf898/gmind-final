@model Gamingv1.ViewModels.GameStoreViewModel
@{
    ViewData["Title"] = "Game Store";
}

<div class="container">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4 text-center mb-3">
                <i class="bi bi-grid-3x3-gap"></i> Educational Games
            </h1>
            <p class="lead text-center text-muted">
                Discover amazing educational games that make learning fun and engaging
            </p>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label for="search" class="form-label">Search Games</label>
                            <input type="text" class="form-control" id="search" name="search" 
                                   value="@Model.SearchTerm" placeholder="Search by title or description...">
                        </div>
                        <div class="col-md-4">
                            <label for="categoryId" class="form-label">Category</label>
                            <select class="form-select" id="categoryId" name="categoryId">
                                <option value="">All Categories</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.CategoryId" selected="@(Model.SelectedCategoryId == category.CategoryId)">
                                        @category.Name
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary me-2">
                                <i class="bi bi-search"></i> Search
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-clockwise"></i> Reset
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Games Grid -->
    @if (Model.Games.Any())
    {
        <div class="row">
            @foreach (var game in Model.Games)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-0 game-card">
                        @if (game.GameImages.Any())
                        {
                            <img src="@game.GameImages.First().ImageUrl" class="card-img-top" alt="@game.Title" 
                                 style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" 
                                 style="height: 250px;">
                                <i class="bi bi-grid-3x3-gap text-muted" style="font-size: 4rem;"></i>
                            </div>
                        }
                        
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title">@game.Title</h5>
                                <span class="badge bg-primary">@game.Category.Name</span>
                            </div>
                            
                            <p class="card-text text-muted flex-grow-1">
                                @(game.Description.Length > 120 ? game.Description.Substring(0, 120) + "..." : game.Description)
                            </p>
                            
                            @if (game.GameReviews.Any())
                            {
                                <div class="mb-2">
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            @if (i <= game.GameReviews.Average(r => r.Rating))
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star"></i>
                                            }
                                        }
                                    </span>
                                    <small class="text-muted">(@game.GameReviews.Count() reviews)</small>
                                </div>
                            }
                            
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="h5 text-success mb-0">$@game.Price.ToString("F2")</span>
                                <a href="@Url.Action("Details", new { id = game.GameId })" class="btn btn-primary">
                                    <i class="bi bi-eye"></i> View Details
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        
        <!-- Pagination placeholder -->
        <div class="row">
            <div class="col-12 text-center">
                <p class="text-muted">Showing @Model.Games.Count() games</p>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12 text-center">
                <div class="py-5">
                    <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
                    <h3 class="mt-3">No games found</h3>
                    <p class="text-muted">Try adjusting your search criteria or browse all categories.</p>
                    <a href="@Url.Action("Index")" class="btn btn-primary">
                        <i class="bi bi-grid-3x3-gap"></i> View All Games
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .game-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .game-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15) !important;
    }
</style>
